# PicoPlus — Required Environment Variables
#
# Copy this file to .env for local development (loaded by DotNetEnv).
# In Production (Liara / Docker) set these as platform environment variables.
# NEVER commit a populated .env file — only this .env.example is safe to commit.

# ── HubSpot ──────────────────────────────────────────────────────────────────
HUBSPOT_TOKEN=

# ── Zohal ────────────────────────────────────────────────────────────────────
ZOHAL_TOKEN=

# ── IPPanel Edge API ─────────────────────────────────────────────────────────
# Set IPPanel:ApiKey and pattern IDs via User Secrets / config, not env vars.
# The IpPanelClient reads IPPanel:ApiKey from IConfiguration.

# ── FarazSMS (if using FarazSMS provider) ────────────────────────────────────
FARAZSMS_USER=
FARAZSMS_PASSWORD=
FARAZSMS_BASEURL=https://ippanel.com/api/select
FARAZSMS_FROM_NUMBER=3000505
FARAZSMS_PATTERN_OTP=
FARAZSMS_PATTERN_WELCOME=
FARAZSMS_PATTERN_DEAL_CLOSED=

# ── SMS.ir (if using SMS.ir provider) ────────────────────────────────────────
SMSIR_API_KEY=
SMSIR_OTP_TEMPLATE_ID=

# ── Liara Deployment API ─────────────────────────────────────────────────────
LIARA_API_TOKEN=
LIARA_PROJECT_ID=
