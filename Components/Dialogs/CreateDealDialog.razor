@using Microsoft.AspNetCore.Components.Forms
@using PicoPlus.ViewModels.Deal
@using PicoPlus.Views
@inject DealCreateDialogViewModel ViewModel
@implements IAsyncDisposable

@if (IsVisible)
{
    <div class="modal-overlay" @onclick="HandleOverlayClick">
        <div class="modal-dark" @onclick:stopPropagation="true">
            
            <!-- Header -->
            <div class="modal-dark-header">
                <h5 class="modal-dark-title">
                    <span class="icon-bg me-2">🚀</span>
                    ایجاد معامله جدید
                </h5>
                <button type="button" class="btn-close-dark" @onclick="HandleCancel" title="بستن">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <EditForm Model="@ViewModel" OnValidSubmit="@HandleSubmit">
                <DataAnnotationsValidator />
                
                <div class="modal-dark-body" dir="rtl">
                    @if (!string.IsNullOrEmpty(ViewModel.ErrorMessage))
                    {
                        <div class="alert alert-danger d-flex align-items-center mb-4" role="alert">
                            <i class="bi bi-exclamation-octagon-fill fs-4 me-2"></i>
                            <div>@ViewModel.ErrorMessage</div>
                        </div>
                    }

                    <!-- Section 1: اطلاعات اصلی و ساختار -->
                    <div class="form-section">
                        <span class="section-title">اطلاعات پایه</span>
                        <div class="row g-3">
                            <!-- Deal Name -->
                            <div class="col-12">
                                <label class="dark-label">
                                    نام معامله <span class="text-danger">*</span>
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text bg-dark border-secondary text-secondary"><i class="bi bi-tag"></i></span>
                                    <InputText class="dark-input form-control border-secondary text-white bg-dark" 
                                               @bind-Value="ViewModel.DealName"
                                               placeholder="مثلاً: فروش نرم‌افزار به شرکت X"
                                               disabled="@ViewModel.IsLoading" />
                                </div>
                                <ValidationMessage For="@(() => ViewModel.DealName)" class="text-danger small mt-1" />
                            </div>

                            <!-- Pipeline & Stage -->
                            <div class="col-md-6">
                                <label class="dark-label">کاریز (Pipeline) <span class="text-danger">*</span></label>
                                <InputSelect class="dark-input form-select" 
                                             @bind-Value="ViewModel.SelectedPipelineId"
                                             disabled="@ViewModel.IsLoading">
                                    <option value="">-- انتخاب کنید --</option>
                                    @if (ViewModel.Pipelines != null)
                                    {
                                        foreach (var pipeline in ViewModel.Pipelines)
                                        {
                                            <option value="@pipeline.id">@pipeline.label</option>
                                        }
                                    }
                                </InputSelect>
                                <ValidationMessage For="@(() => ViewModel.SelectedPipelineId)" class="text-danger small" />
                            </div>

                            <div class="col-md-6">
                                <label class="dark-label">مرحله (Stage) <span class="text-danger">*</span></label>
                                <InputSelect class="dark-input form-select" 
                                             @bind-Value="ViewModel.SelectedDealStage"
                                             disabled="@(ViewModel.IsLoading || string.IsNullOrEmpty(ViewModel.SelectedPipelineId))">
                                    <option value="">-- انتخاب کنید --</option>
                                    @if (ViewModel.DealStages != null)
                                    {
                                        foreach (var stage in ViewModel.DealStages)
                                        {
                                            <option value="@stage.id">@stage.label</option>
                                        }
                                    }
                                </InputSelect>
                                <ValidationMessage For="@(() => ViewModel.SelectedDealStage)" class="text-danger small" />
                            </div>
                        </div>
                    </div>

                    <!-- Section 2: مسئول و اولویت (جایگزین سکشن مالی شد) -->
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="dark-label">مسئول معامله <span class="text-danger">*</span></label>
                            <InputSelect class="dark-input form-select" 
                                         @bind-Value="ViewModel.SelectedOwnerId"
                                         disabled="@ViewModel.IsLoading">
                                <option value="">-- انتخاب کنید --</option>
                                @if (ViewModel.Owners != null)
                                {
                                    foreach (var owner in ViewModel.Owners)
                                    {
                                        <option value="@owner.id">@($"{owner.firstName} {owner.lastName}")</option>
                                    }
                                }
                            </InputSelect>
                            <ValidationMessage For="@(() => ViewModel.SelectedOwnerId)" class="text-danger small" />
                        </div>

                        <div class="col-md-6">
                            <label class="dark-label">اولویت</label>
                            <InputSelect class="dark-input form-select" 
                                         @bind-Value="ViewModel.Priority"
                                         disabled="@ViewModel.IsLoading">
                                <option value="">-- انتخاب کنید --</option>
                                <option value="low">🟢 پایین</option>
                                <option value="medium">🟡 متوسط</option>
                                <option value="high">🔴 بالا</option>
                            </InputSelect>
                        </div>

                        <div class="col-12">
                            <label class="dark-label">توضیحات تکمیلی</label>
                            <InputTextArea class="dark-input" 
                                           @bind-Value="ViewModel.Description"
                                           placeholder="نکاتی که باید درباره این معامله بدانیم..."
                                           rows="3"
                                           disabled="@ViewModel.IsLoading" />
                        </div>
                    </div>

                    <!-- Contact Info Box -->
                    <div class="info-box-dark mb-3">
                        <div class="d-flex align-items-center">
                            <div class="fs-3 me-3 text-primary">
                                <i class="bi bi-person-vcard"></i>
                            </div>
                            <div>
                                <h6 class="mb-1 text-white">اتصال به مخاطب</h6>
                                @if (!string.IsNullOrEmpty(ContactName))
                                {
                                    <div class="text-light opacity-75 small">
                                        این معامله برای 
                                        <span class="badge bg-primary mx-1">@ContactName</span>
                                        ثبت خواهد شد.
                                    </div>
                                }
                                else
                                {
                                    <small class="text-muted">هیچ مخاطبی انتخاب نشده است.</small>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Line Items -->
                    <div class="line-item-section mt-4">
                        <div class="d-flex align-items-center mb-3 border-bottom border-secondary pb-2">
                            <i class="bi bi-cart3 me-2 text-warning"></i>
                            <h6 class="text-white m-0">اقلام معامله (Products/Services)</h6>
                        </div>
                        <SeletedLineItemPane @ref="lineItemPane" />
                    </div>

                </div>

                <!-- Footer -->
                <div class="modal-dark-footer">
                    <button type="button" 
                            class="btn-secondary-dark" 
                            @onclick="HandleCancel"
                            disabled="@ViewModel.IsLoading">
                        انصراف
                    </button>
                    <button type="submit" 
                            class="btn-primary-dark" 
                            disabled="@ViewModel.IsLoading">
                        @if (ViewModel.IsLoading)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                            <span>در حال پردازش...</span>
                        }
                        else
                        {
                            <i class="bi bi-check-lg me-2"></i>
                            <span>ثبت نهایی معامله</span>
                        }
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    // ... کد C# بدون تغییر باقی می‌ماند (فقط حواستان به نکته زیر باشد) ...
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public string? ContactId { get; set; }
    [Parameter] public string? ContactName { get; set; }
    [Parameter] public EventCallback<string> OnDealCreated { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    private SeletedLineItemPane lineItemPane;

    protected override async Task OnInitializedAsync()
    {
        await ViewModel.InitializeAsync(ContactId);
    }

    protected override async Task OnParametersSetAsync()
    {
        if (IsVisible && !string.IsNullOrEmpty(ContactId))
        {
            await ViewModel.InitializeAsync(ContactId);
        }
    }

    private async Task HandleSubmit()
    {
        if (lineItemPane != null)
        {
            ViewModel.LineItems = lineItemPane.GetLineItems();
        }
        var dealId = await ViewModel.CreateDealAsync();
        if (!string.IsNullOrEmpty(dealId))
        {
            await OnDealCreated.InvokeAsync(dealId);
        }
    }

    private async Task HandleCancel()
    {
        await OnCancel.InvokeAsync();
    }

    private async Task HandleOverlayClick()
    {
        if (!ViewModel.IsLoading)
        {
            await HandleCancel();
        }
    }

    public async ValueTask DisposeAsync()
    {
        await Task.CompletedTask;
    }
}
