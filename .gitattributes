# Auto-detect text files and normalize line endings to LF in the repo
* text=auto eol=lf

# Force these to always be LF
*.cs text eol=lf
*.razor text eol=lf
*.json text eol=lf
*.md text eol=lf
*.css text eol=lf
*.js text eol=lf
*.html text eol=lf
*.xml text eol=lf
*.resx text eol=lf
*.sln text eol=lf
*.csproj text eol=lf

# Binary files - no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.map binary
